# /usr/local/nginx/conf/sites-available/analytics-service.conf
#
# ⚠️ 这台 CVM 上 nginx.conf 只 include 了
#   /usr/local/nginx/conf/sites-available/*.conf
# 所以文件必须放这个目录、必须以 .conf 结尾，才会生效。
#
# 首次部署时用「阶段 A：仅 :80」的最简 conf 上线，等 certbot webroot 拿到
# 证书后，再替换成下面这份完整版（:80 acme + 301 + :443 SSL）。
# 具体见 DEPLOY.md。

server {
    listen 80;
    server_name analytics.picturebookpedia.cn;

    # letsencrypt renew 走 webroot
    location /.well-known/acme-challenge/ {
        root /var/www/certbot;
    }
    location / {
        return 301 https://$host$request_uri;
    }
}

server {
    listen 443 ssl http2;
    server_name analytics.picturebookpedia.cn;

    ssl_certificate     /etc/letsencrypt/live/analytics.picturebookpedia.cn/fullchain.pem;
    ssl_certificate_key /etc/letsencrypt/live/analytics.picturebookpedia.cn/privkey.pem;

    client_max_body_size 1m;

    access_log /var/log/nginx/analytics.access.log;
    error_log  /var/log/nginx/analytics.error.log;

    location / {
        proxy_pass http://127.0.0.1:8320;
        proxy_set_header Host              $host;
        proxy_set_header X-Real-IP         $remote_addr;
        proxy_set_header X-Forwarded-For   $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
        proxy_read_timeout 30s;
    }
}
