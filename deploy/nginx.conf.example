# /etc/nginx/sites-available/analytics.picturebookpedia.cn
#
# 首次部署时只有 :80 段（certbot 还没申请证书）。跑
# `certbot --nginx -d analytics.picturebookpedia.cn` 后，certbot 会自动
# 在下面追加 :443 server 段、挂上证书、并把 :80 改成 301 → :443。
# 之后这份文件就长得像 https://ssl-config.mozilla.org 的推荐配置。

server {
    listen 80;
    listen [::]:80;
    server_name analytics.picturebookpedia.cn;

    client_max_body_size 1m;

    access_log /var/log/nginx/analytics.access.log;
    error_log  /var/log/nginx/analytics.error.log;

    location / {
        proxy_pass http://127.0.0.1:8320;
        proxy_set_header Host              $host;
        proxy_set_header X-Real-IP         $remote_addr;
        proxy_set_header X-Forwarded-For   $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
        proxy_read_timeout 30s;
    }
}
